    }

    def Scope "Materials"
    {
        def Material "Default"
        {
            token outputs:surface.connect = </Ball/Materials/Default/surfaceShader.outputs:surface>

            def Shader "surfaceShader"
            {
                uniform token info:id = "UsdPreviewSurface"
                token outputs:surface
            }
        }
    }
}
